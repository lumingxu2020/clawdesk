{
  "name": "qclaw-desktop",
  "version": "1.3.0",
  "description": "QClaw Desktop - OpenClaw图形化管理工具",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "author": "QClaw Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "electron-log": "^5.0.0"
  },
  "build": {
    "appId": "com.clawdesk.desktop",
    "productName": "ClawDesk",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    }
  }
}
